# --- Database (Prisma) ---
# PostgreSQL connection string (pooled URL for serverless hosts)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Direct (non-pooled) URL — used by Prisma Migrate; optional for some hosts
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Auth (JWT in httpOnly cookie) ---
# Long random string in production (never commit real values)
JWT_SECRET="replace-with-a-long-random-string"
# Optional: jsonwebtoken duration (e.g. 1h, 7d) or seconds as digits only
JWT_EXPIRY="1h"

# --- YouTube (landing / lib/youtube.ts) ---
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""

# --- Runtime (set by Next.js / Node — document only) ---
# NODE_ENV is normally "development" | "production" | "test" (do not rely on .env for security)
